# Travelio Environment Variables
# Copy this file to .env and fill in your values

# Database
MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"
CORS_ORIGINS="*"

# Emergent LLM Key (for Claude Sonnet 4.5 intent parsing)
EMERGENT_LLM_KEY=

# AviationStack API (live flight data)
# Get key at: https://aviationstack.com/signup/free
AVIATIONSTACK_API_KEY=

# MTN MoMo Sandbox (payments)
# Get credentials at: https://momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_ENVIRONMENT=sandbox
MOMO_CURRENCY=XOF
MOMO_CALLBACK_URL=

# WhatsApp Cloud API (ticket delivery)
# Get credentials at: https://developers.facebook.com/docs/whatsapp
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
