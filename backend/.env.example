# Travelio WhatsApp Agent - Environment Variables
# Copy to .env and fill in your values

# Database
MONGO_URL="mongodb://localhost:27017"
DB_NAME="travelio"
CORS_ORIGINS="*"

# Emergent LLM Key (Claude Sonnet 4.5 for intent parsing)
EMERGENT_LLM_KEY=

# Amadeus API (flight search)
# Get free test credentials at: https://developers.amadeus.com
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# OpenAI Whisper (voice transcription)
OPENAI_API_KEY=

# MTN MoMo Sandbox (payments)
# Get credentials at: https://momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_ENVIRONMENT=sandbox
MOMO_CURRENCY=EUR

# WhatsApp Cloud API
# Get credentials at: https://developers.facebook.com/docs/whatsapp
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=travelio_verify_2024

# App URL (for PDF ticket links)
APP_BASE_URL=https://your-app-url.com
