# Travelioo Environment Configuration
# Copy this file to backend/.env and fill in your values

# === Database ===
MONGO_URL="mongodb://localhost:27017"
DB_NAME="travelioo"

# === Application ===
CORS_ORIGINS="*"
APP_BASE_URL=https://your-domain.com

# === WhatsApp Cloud API ===
WHATSAPP_PHONE_ID=your_phone_id_here
WHATSAPP_TOKEN=your_permanent_system_token_here
WHATSAPP_VERIFY_TOKEN=travelioo_verify_2024
WHATSAPP_WEBHOOK_SECRET=your_app_secret_here
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# === AI Services ===
EMERGENT_LLM_KEY=your_emergent_key_here

# === Duffel GDS ===
# Prefix duffel_test_ for sandbox, duffel_live_ for production
DUFFEL_API_KEY=duffel_test_your_key_here
DUFFEL_ENV=sandbox

# === Stripe (Google Pay / Apple Pay) ===
# Prefix sk_test_ for test, sk_live_ for production
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# === MTN MoMo ===
MOMO_SUBSCRIPTION_KEY=your_subscription_key_here
MOMO_API_USER=your_uuid_here
MOMO_API_KEY=your_api_key_here
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_ENVIRONMENT=sandbox
MOMO_CURRENCY=XOF
MOMO_CALLBACK_URL=https://your-domain.com/api/momo/callback

# === Moov Money ===
MOOV_API_KEY=your_moov_key_here
MOOV_BASE_URL=https://api.moov-africa.bj
MOOV_CURRENCY=XOF
MOOV_CALLBACK_URL=https://your-domain.com/api/moov/callback

# === Google Pay / Apple Pay ===
GOOGLE_PAY_MERCHANT_ID=your_merchant_id_here
GOOGLE_PAY_ENVIRONMENT=TEST
APPLE_PAY_DOMAIN=your-domain.com

# === Encryption ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your_random_encryption_key_here
